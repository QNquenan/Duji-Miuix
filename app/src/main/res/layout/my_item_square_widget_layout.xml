<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_item_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_surface_bg"
    android:orientation="vertical"
    android:padding="14dp">

    <TextView
        android:id="@+id/widget_item_icon"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:background="@drawable/widget_secondary_container_bg"
        android:gravity="center"
        android:text="📦"
        android:textSize="22sp" />

    <TextView
        android:id="@+id/widget_item_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:maxLines="1"
        android:paddingTop="14dp"
        android:text="我的物品"
        android:textColor="@color/widget_text_primary"
        android:textSize="15sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/widget_item_date"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:maxLines="1"
        android:text="请点击配置"
        android:textColor="@color/widget_text_secondary"
        android:textSize="11sp" />

    <TextView
        android:id="@+id/widget_item_average_price"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="18dp"
        android:textColor="@color/widget_text_primary"
        android:textSize="14sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/widget_item_total_price"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/widget_text_secondary"
        android:textSize="11sp" />
</LinearLayout>
