<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_wide_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_black_surface_bg"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:id="@+id/widget_wide_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="我的物品"
        android:textColor="@color/widget_on_dark"
        android:textSize="18sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingTop="28dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <TextView
                android:id="@+id/widget_wide_total_value_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="物品价值"
                android:textColor="@color/widget_on_dark_secondary"
                android:textSize="12sp" />
            <TextView
                android:id="@+id/widget_wide_total_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="¥0"
                android:textColor="@color/widget_on_dark"
                android:textSize="24sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <TextView
                android:id="@+id/widget_wide_item_count_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="物品数量"
                android:textColor="@color/widget_on_dark_secondary"
                android:textSize="12sp" />
            <TextView
                android:id="@+id/widget_wide_item_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="@color/widget_on_dark"
                android:textSize="24sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <TextView
                android:id="@+id/widget_wide_daily_price_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="总日均价格"
                android:textColor="@color/widget_on_dark_secondary"
                android:textSize="12sp" />
            <TextView
                android:id="@+id/widget_wide_daily_price"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="¥0"
                android:textColor="@color/widget_on_dark"
                android:textSize="24sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
